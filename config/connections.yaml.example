# Oracle Validator - Connection Configuration
# Bu dosyayı kopyalayıp connections.yaml adıyla kaydedin:
#   cp config/connections.yaml.example config/connections.yaml
#
# Şifre için iki yöntem:
#   1. Düz metin    : password: "MyPass123"
#   2. Env variable : password: "$SOURCE_DB_PASS"  → export SOURCE_DB_PASS=MyPass123

source:
  host: source-db.example.com
  port: 1521
  service: ORCL11G          # service_name (SID değil)
  username: valuser
  password: "$SOURCE_DB_PASS"
  # sysdba: true            # SYSDBA bağlantısı için uncomment et
  # wallet_location: ""     # Oracle Wallet kullanıyorsanız
  #
  # Oracle 11g gibi eski versiyonlar thin mode desteklemez.
  # Oracle Instant Client kurulduktan sonra aşağıdaki satırları aktif edin:
  # thick_mode: true
  # client_lib_dir: ""      # Boş = sistem PATH. Örnek: C:/oracle/instantclient_21_9

target:
  host: target-db.example.com
  port: 1521
  service: ORCL19C
  username: valuser
  password: "$TARGET_DB_PASS"
  # sysdba: true
