# Oracle Validator - Connection Configuration
# Bu dosyayı kopyalayıp connections.yaml adıyla kaydedin:
#   cp config/connections.yaml.example config/connections.yaml
#
# Şifre için iki yöntem:
#   1. Düz metin    : password: "MyPass123"
#   2. Env variable : password: "$SOURCE_DB_PASS"  → export SOURCE_DB_PASS=MyPass123

# ---------------------------------------------------------------------------
# Oracle Client modu (python-oracledb sürücüsü) — process-global ayar
#   mode: thin   → Oracle Instant Client gerekmez (Oracle 12.1+)
#   mode: thick  → Instant Client gerekir; Oracle 11g için ZORUNLU.
#                  (11.2.0.4 thin mode'da DPY-3010 hatası verir)
#   lib_dir: Instant Client dizini. Boş = sistem PATH.
#            Örnek (Windows): C:/oracle/instantclient_21_9
#            Örnek (Linux):   /opt/oracle/instantclient_21_9
# ---------------------------------------------------------------------------
oracle_client:
  mode: thick
  lib_dir: ""

source:
  host: source-db.example.com
  port: 1521
  service: ORCL11G          # service_name (SID değil)
  username: valuser
  password: "$SOURCE_DB_PASS"
  # sysdba: true            # SYSDBA bağlantısı için uncomment et
  # wallet_location: ""     # Oracle Wallet kullanıyorsanız
  #
  # read_only: source production olduğu için varsayılan TRUE'dur — bu bağlantıya
  # DBMS_STATS dahil hiçbir yazma yapılmaz. Yalnızca gerçekten gerekiyorsa açın:
  # read_only: false

target:
  host: target-db.example.com
  port: 1521
  service: ORCL19C
  username: valuser
  password: "$TARGET_DB_PASS"
  # sysdba: true
  # read_only: false        # target varsayılanı zaten false (stats yenilenebilir)
